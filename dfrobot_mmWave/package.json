{
  "name": "dfrobot-mmwave-addons",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c cyan,magenta \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --if-present --workspaces",
    "test": "npm run test --if-present --workspaces"
  },
  "devDependencies": {
    "concurrently": "9.2.4",
    "jsdom": "24.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
